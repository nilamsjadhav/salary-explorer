{
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14"
  },
  "scripts": {
    "buildServer": "cd server && npm install",
    "buildClient": "cd client && npm run build",
    "client": "cd client && npm start",
    "server": "cd server && nodemon server.js",
    "dev": "concurrently \"npm run client\" \"npm run server\""
  }
}
